{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": false,
  "tsx": false,
  "tailwind": {
    "config": "",
    "css": "src/index.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@sona-ui": "https://sona-ui.vercel.app/r/{name}.json",
    "@magicui": "https://magicui.design/r/{name}",
    "@animbits": "https://animbits.dev/r/{name}.json",
    "@systaliko-ui": "https://systaliko-ui.vercel.app/r/{name}.json"
  }
}
